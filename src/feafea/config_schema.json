{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "FeaFea",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "flags": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "variants": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      },
                      "minItems": 2,
                      "uniqueItems": true
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
                      },
                      "minItems": 2,
                      "uniqueItems": true
                    }
                  ]
                },
                "default": {
                  "type": ["string", "integer", "boolean"]
                },
                "metadata": {
                  "type": "object",
                  "additionalProperties": false,
                  "patternProperties": {
                    "^[a-zA-Z_][a-zA-Z0-9_]*$": {}
                  }
                }
              },
              "if": {
                "properties": {
                  "default": {
                    "type": ["boolean"]
                  }
                },
                "required": ["default"]
              },
              "then": {
                "required": ["default"]
              },
              "else": {
                "required": ["variants", "default"]
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "alias": {
                  "type": "string"
                }
              },
              "required": ["alias"]
            }
          ]
        }
      }
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "rules": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": {
          "type": "object",
          "additionalProperties": false,
          "required": ["variants"],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "filter": {
              "type": "string"
            },
            "variants": {
              "type": "object",
              "additionalProperties": false,
              "minProperties": 1,
              "patternProperties": {
                "^[a-zA-Z_][a-zA-Z0-9_]*$": {
                  "type": ["string", "integer", "boolean"]
                }
              }
            },
            "split_group": {
              "type": "string",
              "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
            },
            "priority": {
              "type": "integer",
              "minimum": 0
            },
            "metadata": {
              "type": "object",
              "additionalProperties": false,
              "patternProperties": {
                "^[a-zA-Z_][a-zA-Z0-9_]*$": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
